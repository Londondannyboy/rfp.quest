# Database (Neon Postgres)
DATABASE_URL=postgres://user:password@host/database

# Neon Auth (for Google OAuth)
# Get this from Neon Console > Your Project > Auth > Configuration
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/dbname/auth

# Note: Find a Tender API is PUBLIC - no API key required
# Docs: https://www.find-tender.service.gov.uk/apidocumentation/1.0/GET-ocdsReleasePackages

# Neo4j Aura (Phase 2 - Graph Database)
# NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=rfpquest

# Agent Backend (Railway in production, localhost in dev)
AGENT_URL=http://localhost:8000

# Web Search (for buyer/competitor research)
TAVILY_API_KEY=your-tavily-api-key

# Session
SESSION_SECRET=your-random-secret

# App URL (for internal API calls)
NEXT_PUBLIC_APP_URL=http://localhost:3000
